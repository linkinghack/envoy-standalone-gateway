  "routes": {
    "rc/http": {
      "name": "rc/http",
      "virtual_hosts": [
        {
          "domains": [
            "*"
          ],
          "name": "vh/http-redirect",
          "routes": [
            {
              "match": {
                "prefix": "/"
              },
              "redirect": {
                "scheme_redirect": "https"
              }
            }
          ]
        }
      ]
    },
    "rc/https": {
      "name": "rc/https",
      "virtual_hosts": [
        {
          "domains": [
            "blog.example.com"
          ],
          "name": "vh/blog",
          "routes": [
            {
              "match": {
                "prefix": "/"
              },
              "route": {
                "cluster": "us/blog-app",
                "timeout": "15s"
              }
            }
          ]
        },
        {
          "domains": [
            "www.example.com"
          ],
          "name": "vh/www",
          "routes": [
            {
              "match": {
                "prefix": "/"
              },
              "route": {
                "cluster": "us/www-app",
                "timeout": "15s"
              }
            }
          ]
        }
      ]
    }
  },
